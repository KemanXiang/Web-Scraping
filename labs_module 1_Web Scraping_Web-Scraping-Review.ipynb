   "source": [
    "We can also use the `match` parameter to select the specific table we want. If the table contains a string matching the text it will be read.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 68,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "   Rank                 Country  Population  Area (km2)  Density (pop/km2)\n0     1               Singapore     5921231         719               8235\n1     2              Bangladesh   165650475      148460               1116\n2     3  Palestine[note 3][103]     5223000        6025                867\n3     4          Taiwan[note 4]    23580712       35980                655\n4     5             South Korea    51844834       99720                520"
     ]
    }
   ],
   "source": [
    "heading = soup.find(\"h3\", {\"id\": \"Most_densely_populated_countries\"})\n",
    "\n",
    "# Get the next table after this heading\n",
    "table = heading.find_next(\"table\")\n",
    "\n",
    "# Convert to DataFrame\n",
    "df = pd.read_html(StringIO(str(table)))[0]\n",
    "print(df.head())"
   ]
